# =============================================================================
# Maintify — environment variables template
# =============================================================================
# Run scripts/dev-setup.sh to generate .env automatically.
# Or, copy this file to .env and fill in your own values manually.
# The .env file is gitignored and must NEVER be committed.
#
#   bash scripts/dev-setup.sh    # recommended
#   # or:
#   cp .env.example .env && $EDITOR .env
# =============================================================================

# --- Database ---
DB_USER=maintify
DB_NAME=maintify_core
DB_PASSWORD=change_me_db_password

# --- Builder service ---
BUILDER_API_KEY=change_me_builder_api_key

# --- Core service ---
JWT_SECRET=change_me_jwt_secret_min_32_chars

# --- Initial administrator ---
# Used once on first boot to seed the system-admin account via rbac-cli.
# Can be removed from .env after the account is created.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_min_12_chars
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
