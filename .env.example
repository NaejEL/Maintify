# --- Database ---
DB_USER=maintify
DB_NAME=maintify_core
DB_PASSWORD=change_me_db_password

# --- Builder service ---
BUILDER_API_KEY=change_me_builder_api_key

# --- Core service ---
JWT_SECRET=change_me_jwt_secret_min_32_chars
