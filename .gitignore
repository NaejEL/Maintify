# =============================================================================
# Maintify — root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Private / work-in-progress documents (kept in _dev/, never shared)
# -----------------------------------------------------------------------------
_dev/

# -----------------------------------------------------------------------------
# Environment & secrets — use .env.example as the committed template
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
secrets/

# -----------------------------------------------------------------------------
# Go build artefacts
# -----------------------------------------------------------------------------
# Compiled binaries (named after the module or any ELF/Mach-O/PE output)
core/core
builder/builder
core/cmd/rbac-cli/rbac-cli
plugins/asset-tracker/asset-tracker

# Generic binary patterns
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test & coverage artefacts produced by `go test`
*.out
*.test
coverage.html
coverage.txt
*_coverage.out

# Go workspace / module cache (local only)
vendor/
.gopath/

# -----------------------------------------------------------------------------
# Test result artefacts (generated by CI / Docker test containers)
# -----------------------------------------------------------------------------
test-results/

# -----------------------------------------------------------------------------
# Frontend (web/)
# – web/.gitignore already covers node_modules and dist inside web/,
#   but be explicit here as a safety net
# -----------------------------------------------------------------------------
web/node_modules/
web/dist/
web/dist-ssr/
web/.env
web/.env.local
web/.env.*.local

# -----------------------------------------------------------------------------
# Docker / container leftovers
# -----------------------------------------------------------------------------
# Ignore locally-generated docker override files
docker-compose.override.yml

# -----------------------------------------------------------------------------
# IDE and editor directories
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.sw?
*.vim

# -----------------------------------------------------------------------------
# OS artefacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# Backup files
*.bak
*.orig
*.tmp
*~

# SonarQube local cache
.sonar/
.scannerwork/
